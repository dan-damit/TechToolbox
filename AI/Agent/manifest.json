{
  "Get-SystemHealth": {
    "description": "Collects detailed system health metrics for diagnostics.",
    "category": "Diagnostics",
    "parameters": {
      "ComputerName": {
        "type": "string",
        "required": false,
        "description": "Target computer; defaults to local."
      },
      "Verbose": {
        "type": "bool",
        "required": false,
        "description": "Enable verbose logging."
      }
    },
    "returns": {
      "type": "object",
      "schemaHint": "HealthReportV1"
    }
  },

  "Invoke-NetworkDiagnostics": {
    "description": "Runs layered network diagnostics and returns a structured summary.",
    "category": "Networking"
  }
}
