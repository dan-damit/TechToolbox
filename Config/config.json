      "includeTimestamps": true,
      "logPath": "%TT_Home%\\LogsAndExports\\Logs",
      "enableConsole": true,
      "enableFileLogging": true,
      "logFile": "TechToolbox.log",
      "logFileNameFormat": "TechToolbox_{yyyyMMdd}.log",
      "minimumLevel": "Info",
      "minimumLevelInt": 2,
      "useAnsi": true
