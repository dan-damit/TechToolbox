            if ($Force) { $trArgs += ' /f' }

            $st = $Target.ToString('HH:mm')
            $sd = $Target.ToString('MM/dd/yyyy', [cultureinfo]::InvariantCulture)

            & schtasks.exe /Delete /TN $TaskName /F 2>$null | Out-Null

            $createArgs = @(
                '/Create',
                '/SC', 'ONCE',
                '/TN', $TaskName,
                '/TR', $trArgs,
                '/ST', $st,
                '/SD', $sd,
                '/RU', 'SYSTEM',
                '/F'
            )

            & schtasks.exe @createArgs | Out-Null

